# Apache Pinot
PINOT_BROKER_URL=http://localhost:8099
PINOT_CONTROLLER_URL=http://localhost:9000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Autenticación
JWT_SECRET=cambia_este_secreto_en_produccion

# RAWG API — https://rawg.io/apidocs
RAWG_API_KEY=

# Frontend (URLs de redirección Stripe)
FRONTEND_URL=http://localhost:4200

# Stripe sandbox — https://stripe.com/docs/keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Opcional: directorio de avatares (default en contenedor: /app/static/avatars)
# AVATAR_DIR=/app/static/avatars
